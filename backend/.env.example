# Copy to .env and fill in your RDS values, then: source .env
# Format: postgres://USER:PASSWORD@RDS-ENDPOINT:5432/DBNAME?sslmode=require
export DATABASE_URL="postgres://todoadmin:changeme@my-db.abc123.ap-southeast-1.rds.amazonaws.com:5432/todo?sslmode=require"

# Port the API listens on (default 8080)
export PORT="8080"

# Allowed CORS origin = your S3 static website URL.
# Use "*" while testing, then lock it to your bucket URL for production.
export ALLOWED_ORIGIN="*"
